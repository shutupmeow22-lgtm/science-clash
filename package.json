{
  "name": "science-clash",
  "version": "1.0.0",
  "description": "Real-time multiplayer classroom game",
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "build":       "npm install --prefix client && npm run build --prefix client",
    "start":       "node server/server.js",
    "dev":         "concurrently \"node server/server.js\" \"npm run dev --prefix client\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
